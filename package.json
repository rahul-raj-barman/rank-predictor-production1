{
  "name": "sikshalabh-exam-rank-predictor",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "wasm:build": "cd engines/rank-core && wasm-pack build --target web --release --out-dir ../../apps/web/public/wasm/rank-core",
    "build:cloudflare": "bash scripts/cloudflare-pages-build.sh",
    "dev": "npm run wasm:build && npm --prefix apps/web run dev",
    "build": "npm run wasm:build && npm --prefix apps/web run build",
    "start": "npm --prefix apps/web run start",
    "typecheck": "npm --prefix apps/web run typecheck",
    "rust:test": "cargo test --manifest-path engines/rank-core/Cargo.toml"
  }
}
